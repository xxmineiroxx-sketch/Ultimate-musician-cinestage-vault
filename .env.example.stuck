# Ultimate Playback — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it is already in .gitignore.

# Sync server URL (Cloudflare Pages + Functions)
EXPO_PUBLIC_SYNC_URL=https://ultimatelabs.pages.dev

# CineStage Brain API URL
EXPO_PUBLIC_CINESTAGE_URL=https://cinestage.ultimatelabs.co

# Sync API credentials — use org ID + secret key for service-to-service auth
EXPO_PUBLIC_SYNC_ORG_ID=your-org-id-here
EXPO_PUBLIC_SYNC_SECRET_KEY=your-secret-key-here

# Local development overrides
# EXPO_PUBLIC_SYNC_URL=http://localhost:8099
