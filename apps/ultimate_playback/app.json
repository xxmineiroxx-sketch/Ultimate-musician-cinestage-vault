{
  "expo": {
    "name": "Ultimate Playback",
    "slug": "ultimate-playback",
    "version": "1.3.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "scheme": "ultimateplayback",
    "updates": {
      "url": "https://u.expo.dev/67cddab2-c9c9-45c8-81c4-3ec04e6585e7",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ultimatemusician.playback",
      "buildNumber": "41",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.ultimatemusician.playback"
        ]
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSMicrophoneUsageDescription": "Ultimate Playback uses the microphone for audio monitoring.",
        "NSPhotoLibraryUsageDescription": "Choose a profile photo from your library.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "ultimateplayback"
            ]
          }
        ]
      },
      "runtimeVersion": "1.0.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "package": "com.ultimatemusician.playback",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "ultimateplayback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Ultimate Playback",
      "shortName": "Playback",
      "backgroundColor": "#020617",
      "themeColor": "#020617"
    },
    "extra": {
      "eas": {
        "projectId": "67cddab2-c9c9-45c8-81c4-3ec04e6585e7"
      }
    },
    "owner": "ultimate-dev",
    "plugins": [
      "expo-asset",
      "expo-notifications",
      "./plugins/withNativeModules",
      "expo-font"
    ]
  }
}
