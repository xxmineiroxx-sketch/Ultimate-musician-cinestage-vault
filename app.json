{
  "expo": {
    "name": "Ultimate Playback",
    "slug": "ultimate-playback",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "scheme": "ultimateplayback",
    "updates": {
      "url": "https://u.expo.dev/67cddab2-c9c9-45c8-81c4-3ec04e6585e7",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ultimatemusician.playback",
      "buildNumber": "26",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.ultimatemusician.playback"
        ]
      },
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSMicrophoneUsageDescription": "Ultimate Playback uses the microphone for audio monitoring.",
        "NSPhotoLibraryUsageDescription": "Choose a profile photo from your library.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "ultimateplayback"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "package": "com.ultimatemusician.playback",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "ultimateplayback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "67cddab2-c9c9-45c8-81c4-3ec04e6585e7",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "UltimatePlaybackWatch",
                  "bundleIdentifier": "com.ultimatemusician.playback.watchkitapp",
                  "parentBundleIdentifier": "com.ultimatemusician.playback",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.ultimatemusician.playback"
                    ]
                  }
                },
                {
                  "targetName": "UltimatePlaybackWatchExtension",
                  "bundleIdentifier": "com.ultimatemusician.playback.watchkitapp.watchkitextension",
                  "parentBundleIdentifier": "com.ultimatemusician.playback.watchkitapp"
                },
                {
                  "targetName": "UltimatePlaybackWidget",
                  "bundleIdentifier": "com.ultimatemusician.playback.widget",
                  "parentBundleIdentifier": "com.ultimatemusician.playback",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.ultimatemusician.playback"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "owner": "ultimate-dev",
    "plugins": [
      "expo-asset",
      "expo-notifications",
      "./plugins/withNativeModules"
    ]
  }
}
