{
  "name": "ultimate-playback",
  "version": "0.1.0",
  "description": "Ultimate Playback - Musician's workspace for creating song presets with device setups",
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/fix-ios-build-paths.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "testflight:status": "node scripts/sync-testflight-groups.js --check --warning-days 21",
    "testflight:share-latest": "node scripts/sync-testflight-groups.js --warning-days 21",
    "testflight:beta-lane": "node scripts/sync-testflight-groups.js --warning-days 21 --notify --text",
    "testflight:install-monitor": "node scripts/install-testflight-beta-lane.js --hour 9 --minute 0 --warning-days 21"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "^54.0.0",
    "expo-asset": "^12.0.12",
    "expo-av": "~16.0.8",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-notifications": "^0.32.16",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17"
  },
  "private": true
}
